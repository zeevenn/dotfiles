#!/usr/bin/env bash
#
# Print a compact gh-notify table for the Neovim dashboard.

set -euo pipefail

limit="${1:-5}"

if ! command -v gh >/dev/null 2>&1; then
  exit 0
fi

esc="$(printf '\033')"
ansi="(${esc}\\[[0-9;]*m)*"
reasons="assign|author|comment|invitation|manual|mention|review_requested|security_alert|state_change|subscribed|team_mention|ci_activity"

gh notify -s -a -n "$limit" 2>/dev/null |
  sed -E "s/^(.*${ansi}#[0-9]+${ansi}[[:space:]]+${ansi}(${reasons})${ansi}).*/\\1/"
